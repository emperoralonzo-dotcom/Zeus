<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- INTERNET is used ONLY for the one-time model download. After that, Zeus
         runs fully offline. Remove this line if you ship the model inside the APK. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- RECORD_AUDIO powers the microphone (speak to Zeus). Requested at runtime. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Declares that the app benefits from, but does not require, lots of RAM. -->
    <uses-feature android:name="android.hardware.ram.low" android:required="false" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:largeHeap="true"
        android:theme="@style/Theme.Zeus">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:theme="@style/Theme.Zeus">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
